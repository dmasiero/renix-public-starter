#!/usr/bin/env bash
set -euo pipefail

while [[ $# -gt 0 ]]; do
  case "$1" in
    -v)
      exit 0
      ;;
    -n|-H)
      shift
      ;;
    --)
      shift
      break
      ;;
    -*)
      printf 'demo sudo adapter: unsupported option: %s\n' "$1" >&2
      exit 2
      ;;
    *)
      break
      ;;
  esac
done

[[ $# -gt 0 ]] || exit 0
exec "$@"
