#!/usr/bin/env bash
set -euo pipefail

REAL_NIX_ENV=/root/.nix-profile/bin/nix-env
args=" $* "

if [[ "$args" == *" --profile /nix/var/nix/profiles/system "* ]]; then
  if [[ "$args" == *" --list-generations "* ]]; then
    cat <<'EOF'
   1   2026-07-17 10:00:00
   2   2026-07-18 10:00:00
   3   2026-07-19 10:00:00
   4   2026-07-20 10:00:00
   5   2026-07-21 10:00:00   (current)
EOF
    exit 0
  fi

  if [[ "$args" == *" --delete-generations "* ]]; then
    printf 'demo adapter: preserving the five simulated system generations\n'
    exit 0
  fi
fi

exec "$REAL_NIX_ENV" "$@"
