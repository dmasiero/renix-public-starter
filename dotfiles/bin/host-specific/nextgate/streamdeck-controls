#!/usr/bin/env python3
import io
import json
import os
import subprocess
import threading
import time
from concurrent.futures import ThreadPoolExecutor

import cairosvg
from PIL import Image, ImageDraw, ImageFont
from StreamDeck.DeviceManager import DeviceManager
from StreamDeck.ImageHelpers import PILHelper


KITTY = os.environ["STREAMDECK_KITTY"]
XKILL = os.environ["STREAMDECK_XKILL"]
KASA = os.environ.get("STREAMDECK_KASA", os.path.expanduser("~/dotfiles/bin/host-specific/nextgate/kasa"))
POLL_SECONDS = 300
KASA_TIMEOUT_SECONDS = 4
KASA_COOLDOWN_MAX_SECONDS = 300
TUX_SVG = os.environ.get("STREAMDECK_TUX_SVG", os.path.expanduser("~/dotfiles/streamdeck/images/tux.svg"))
SKULL_PNG = os.environ.get("STREAMDECK_SKULL_PNG", os.path.expanduser("~/dotfiles/streamdeck/images/skull.png"))
DEVICE_KEYS = {
    10: {"label": "Pool\nTable", "target": "192.168.1.155", "type": "plug"},
    11: {"label": "Kitchen\nIsland", "target": "192.168.1.102", "type": "dimmer"},
    12: {"label": "Sink\nLights", "target": "192.168.1.42", "type": "dimmer"},
    13: {"label": "Garage\nNorth", "target": "192.168.1.199", "type": "switch"},
    14: {"label": "Garage\nSouth", "target": "192.168.1.242", "type": "switch"},
}
# Kasa commands go through an SSH jump host. Do not fan out one SSH
# connection per key: sshd can drop bursts with "Not allowed at this time"
# (MaxStartups), which made the bottom-row light buttons unreliable.
executor = ThreadPoolExecutor(max_workers=1)
deck_lock = threading.Lock()
refresh_lock = threading.Lock()
kasa_lock = threading.Lock()
kasa_failures = 0
kasa_cooldown_until = 0.0
state_cache = {}


def tux_icon(deck):
    png_bytes = cairosvg.svg2png(url=TUX_SVG, output_width=512, output_height=512)
    with Image.open(io.BytesIO(png_bytes)) as source:
        source = source.convert("RGBA")
        background = Image.new("RGBA", source.size, "#000000")
        background.alpha_composite(source)
        image = PILHelper.create_scaled_image(deck, background.convert("RGB"), margins=[0, 0, 0, 0])
    return PILHelper.to_native_format(deck, image)


def xkill_icon(deck):
    with Image.open(SKULL_PNG) as source:
        source = source.convert("RGBA")
        background = Image.new("RGBA", source.size, "#000000")
        background.alpha_composite(source)
        image = PILHelper.create_scaled_image(deck, background.convert("RGB"), margins=[0, 0, 0, 0])
    return PILHelper.to_native_format(deck, image)


def blank_image(deck, color="#000000"):
    return PILHelper.to_native_format(deck, Image.new("RGB", deck.key_image_format()["size"], color))


def render_text_key(deck, label, bg_color, accent_color):
    size = deck.key_image_format()["size"]
    image = Image.new("RGB", size, bg_color)
    draw = ImageDraw.Draw(image)
    font = ImageFont.load_default()

    draw.rounded_rectangle((5, 5, size[0] - 6, size[1] - 6), radius=14, outline=accent_color, width=4)
    draw.rectangle((10, 10, size[0] - 11, 18), fill=accent_color)

    line_gap = 4
    lines = label.split("\n")
    boxes = [draw.textbbox((0, 0), line, font=font) for line in lines]
    line_heights = [box[3] - box[1] for box in boxes]
    total_height = sum(line_heights) + (len(lines) - 1) * line_gap
    y = (size[1] - total_height) // 2 + 4

    for line, box, height in zip(lines, boxes, line_heights):
        width = box[2] - box[0]
        x = (size[0] - width) // 2 - box[0]
        draw.text((x, y - box[1]), line, font=font, fill="#ffffff")
        y += height + line_gap

    return PILHelper.to_native_format(deck, image)


def device_key_image(deck, label, is_on):
    if is_on is None:
        return render_text_key(deck, label, "#3a3216", "#f9e2af")
    if is_on:
        return render_text_key(deck, label, "#203a24", "#a6e3a1")
    return render_text_key(deck, label, "#3b1f24", "#f38ba8")


def reset_other_keys(deck):
    blank = blank_image(deck)
    for key in range(2, deck.key_count()):
        if key not in DEVICE_KEYS:
            deck.set_key_image(key, blank)


def launch_kitty():
    subprocess.Popen([KITTY], start_new_session=True)


def launch_xkill():
    subprocess.Popen([XKILL], start_new_session=True)


def kasa_in_cooldown():
    with kasa_lock:
        return time.monotonic() < kasa_cooldown_until


def note_kasa_success():
    global kasa_failures, kasa_cooldown_until
    with kasa_lock:
        kasa_failures = 0
        kasa_cooldown_until = 0.0


def note_kasa_failure(output):
    global kasa_failures, kasa_cooldown_until
    # SSH on the jump host sometimes returns "Not allowed at this time"
    # when it is throttling MaxStartups/penalty traffic. Back off hard
    # instead of hammering it every refresh and making the outage persist.
    throttle_markers = (
        "Not allowed at this time",
        "kex_exchange_identification",
        "Connection reset",
        "Connection closed",
        "failed to start kasa-agent",
    )
    with kasa_lock:
        kasa_failures += 1
        if any(marker in output for marker in throttle_markers):
            delay = min(KASA_COOLDOWN_MAX_SECONDS, 15 * (2 ** min(kasa_failures - 1, 5)))
            kasa_cooldown_until = max(kasa_cooldown_until, time.monotonic() + delay)


def run_kasa(*args):
    if kasa_in_cooldown():
        return None
    try:
        result = subprocess.run(
            [KASA, *args],
            capture_output=True,
            text=True,
            timeout=KASA_TIMEOUT_SECONDS,
        )
    except subprocess.TimeoutExpired as exc:
        output = ((exc.stdout or "") if isinstance(exc.stdout, str) else "") + ((exc.stderr or "") if isinstance(exc.stderr, str) else "")
        note_kasa_failure(output)
        return None
    output = (result.stdout or "") + (result.stderr or "")
    if result.returncode != 0:
        note_kasa_failure(output)
        return None
    note_kasa_success()
    return output.strip()


def kasa_state(target, _device_type):
    output = run_kasa("state", target)
    if output is None:
        return None
    if output.startswith("{"):
        try:
            return bool(json.loads(output).get("is_on"))
        except Exception:
            return None
    for line in output.splitlines():
        if line.startswith("Device state:"):
            return line.split(":", 1)[1].strip() == "True"
    return None


def kasa_toggle(target, _device_type):
    output = run_kasa("toggle", target)
    if output and output.startswith("{"):
        try:
            return bool(json.loads(output).get("is_on"))
        except Exception:
            return None
    return None


def set_device_key(deck, key, label, state):
    state_cache[key] = state
    with deck_lock:
        deck.set_key_image(key, device_key_image(deck, label, state))


def refresh_device_key(deck, key, info):
    state = kasa_state(info["target"], info["type"])
    if state is None and key in state_cache:
        return state_cache[key]
    set_device_key(deck, key, info["label"], state)
    return state


def refresh_device_keys(deck):
    if not refresh_lock.acquire(blocking=False):
        return
    try:
        for key, info in DEVICE_KEYS.items():
            refresh_device_key(deck, key, info)
    finally:
        refresh_lock.release()


def configure(deck):
    deck.open()
    deck.reset()
    deck.set_brightness(30)
    deck.set_key_image(0, tux_icon(deck))
    deck.set_key_image(1, xkill_icon(deck))
    reset_other_keys(deck)
    for device_key, device_info in DEVICE_KEYS.items():
        set_device_key(deck, device_key, device_info["label"], None)

    def on_key_change(_deck, key, state):
        if not state:
            return
        if key == 0:
            launch_kitty()
        elif key == 1:
            launch_xkill()
        elif key in DEVICE_KEYS:
            info = DEVICE_KEYS[key]
            current_state = state_cache.get(key)
            optimistic_state = None if current_state is None else not current_state
            set_device_key(deck, key, info["label"], optimistic_state)

            def toggle_key():
                new_state = kasa_toggle(info["target"], info["type"])
                if new_state is not None:
                    set_device_key(deck, key, info["label"], new_state)

            executor.submit(toggle_key)

    def delayed_refresh(delay):
        time.sleep(delay)
        refresh_device_keys(deck)

    deck.set_key_callback(on_key_change)
    # Background refreshes paint real on/off state after startup without
    # blocking button input. The second pass catches slow SSH mux startup.
    threading.Thread(target=delayed_refresh, args=(0,), daemon=True).start()
    threading.Thread(target=delayed_refresh, args=(8,), daemon=True).start()
    return deck


while True:
    deck = None
    try:
        decks = DeviceManager().enumerate()
        if not decks:
            time.sleep(POLL_SECONDS)
            continue

        deck = configure(decks[0])
        while True:
            time.sleep(POLL_SECONDS)
    except Exception:
        time.sleep(POLL_SECONDS)
    finally:
        if deck is not None:
            try:
                deck.reset()
                deck.close()
            except Exception:
                pass
