#!/usr/bin/env bash
set -euo pipefail

set_speaker_mute_led() {
  local muted="$1"
  local led=/sys/class/leds/platform::mute/brightness
  if [ -w "$led" ]; then
    printf '%s\n' "$muted" > "$led" || true
  fi
}

action="${1:-}"
speaker_mute_state="${XDG_RUNTIME_DIR:-/tmp}/speaker-mute-toggle.state"
case "$action" in
  up)
    wpctl set-mute @DEFAULT_AUDIO_SINK@ 0 >/dev/null 2>&1 || true
    printf '0\n' > "$speaker_mute_state" 2>/dev/null || true
    set_speaker_mute_led 0
    wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+ >/dev/null
    ;;
  down)
    wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%- >/dev/null
    ;;
  toggle)
    # Some ThinkPads emit both XF86AudioMicMute and XF86AudioMute for F4.
    # If a mic mute just happened, ignore the speaker-mute half of that keypress.
    sleep 0.8
    mic_mute_stamp="${XDG_RUNTIME_DIR:-/tmp}/mic-mute-toggle.stamp"
    if [ -r "$mic_mute_stamp" ]; then
      now="$(date +%s%3N)"
      last="$(cat "$mic_mute_stamp" 2>/dev/null || true)"
      if [[ "$last" =~ ^[0-9]+$ ]] && [ $((now - last)) -lt 750 ]; then
        exit 0
      fi
    fi
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle >/dev/null
    ;;
esac

status="$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null || true)"
if printf '%s\n' "$status" | grep -q MUTED; then
  muted=1
else
  muted=0
fi
printf '%s\n' "$muted" > "$speaker_mute_state" 2>/dev/null || true
set_speaker_mute_led "$muted"

volume="$(printf '%s\n' "$status" | awk '{ printf "%d", ($2 * 100) + 0.5 }')"
volume="${volume:-0}"

if [ "$muted" -eq 1 ]; then
  body="Muted"
  hint=0
  icon="audio-volume-muted-symbolic"
else
  body="$volume%"
  hint="$volume"
  if [ "$volume" -ge 67 ]; then
    icon="audio-volume-high-symbolic"
  elif [ "$volume" -ge 34 ]; then
    icon="audio-volume-medium-symbolic"
  elif [ "$volume" -gt 0 ]; then
    icon="audio-volume-low-symbolic"
  else
    icon="audio-volume-muted-symbolic"
  fi
fi

dunstify \
  --app-name=volume \
  --replace=2596 \
  --urgency=low \
  --timeout=1000 \
  --hints=int:value:"$hint" \
  --icon="$icon" \
  "Volume" "$body"
