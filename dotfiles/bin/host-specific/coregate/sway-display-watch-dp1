#!/usr/bin/env bash
set -euo pipefail

internal="eDP-1"
external="DP-1"
last_non10_workspace=""

is_external_active() {
  swaymsg -t get_outputs 2>/dev/null |
    jq -e --arg output "$external" '.[] | select(.name == $output and .active)' >/dev/null
}

update_last_non10_workspace() {
  local focused

  focused="$(
    swaymsg -t get_workspaces 2>/dev/null |
      jq -r '.[] | select(.focused and .name != "10") | .name' 2>/dev/null || true
  )"
  if [ -n "$focused" ]; then
    last_non10_workspace="$focused"
  fi
}

needs_reconcile() {
  local tree_json workspaces_json

  is_external_active || return 1

  workspaces_json="$(swaymsg -t get_workspaces 2>/dev/null || true)"
  if ! jq -e --arg output "$internal" '.[] | select(.name == "10" and .output == $output)' <<<"$workspaces_json" >/dev/null; then
    return 0
  fi

  tree_json="$(swaymsg -t get_tree 2>/dev/null || true)"
  jq -e --arg output "$internal" '
    .. | objects
    | select(.type == "output" and .name == $output)
    | .nodes[]?
    | select(.type == "workspace" and .name != "__i3_scratch" and .name != "10")
    | select(((.nodes // []) | length) + ((.floating_nodes // []) | length) > 0)
  ' <<<"$tree_json" >/dev/null
}

move_internal_workspace_to_external() {
  local tree_json workspaces_json target_workspace

  # Keep workspace 10 visible on the laptop panel whenever this helper runs.
  if ! is_external_active; then
    swaymsg "workspace 10; move workspace to output $internal" >/dev/null || true
    return 1
  fi

  tree_json="$(swaymsg -t get_tree 2>/dev/null || true)"
  [ -n "$tree_json" ] || return 1

  # Use the tree instead of get_workspaces so we only move real/non-empty
  # workspaces, and do not chase the empty replacement workspace Sway creates
  # on eDP-1 after the last real workspace moves away.
  mapfile -t internal_workspaces < <(
    jq -r --arg output "$internal" '
      .. | objects
      | select(.type == "output" and .name == $output)
      | .nodes[]?
      | select(.type == "workspace" and .name != "__i3_scratch" and .name != "10")
      | select(((.nodes // []) | length) + ((.floating_nodes // []) | length) > 0)
      | .name | @json
    ' <<<"$tree_json"
  )

  workspaces_json="$(swaymsg -t get_workspaces 2>/dev/null || true)"
  target_workspace="$(
    jq -r --arg internal "$internal" --arg external "$external" --arg last "$last_non10_workspace" '
      ([.[] | select(.focused and .name != "10") | .name]
       + [.[] | select(.name == $last and .name != "10") | .name]
       + [.[] | select(.output == $internal and .focused and .name != "10") | .name]
       + [.[] | select(.output == $external and .visible and .name != "10") | .name]
       + [.[] | select(.output == $external and .name != "10") | .name]
       | first // empty) | @json
    ' <<<"$workspaces_json"
  )"
  if [ -z "$target_workspace" ] && [ "${#internal_workspaces[@]}" -gt 0 ]; then
    target_workspace="${internal_workspaces[0]}"
  fi

  for workspace in "${internal_workspaces[@]}"; do
    swaymsg "workspace $workspace; move workspace to output $external" >/dev/null
  done

  # Sway leaves an empty replacement workspace on eDP-1 after moving the last
  # real workspace away. Explicitly make workspace 10 the visible eDP-1
  # workspace, then restore focus to the moved DP-1 workspace when possible.
  swaymsg "workspace 10; move workspace to output $internal" >/dev/null || true

  if [ -n "$target_workspace" ]; then
    swaymsg "focus output $external; workspace $target_workspace" >/dev/null || true
  fi

  [ "${#internal_workspaces[@]}" -gt 0 ]
}

move_all_internal_workspaces_to_external() {
  local attempt

  for attempt in {1..12}; do
    sleep 0.5
    move_internal_workspace_to_external || return 0
  done
}

if [ "${1:-}" = "--once" ]; then
  move_all_internal_workspaces_to_external
  exit 0
fi

update_last_non10_workspace

if is_external_active; then
  state="connected"
  move_all_internal_workspaces_to_external
else
  state="disconnected"
fi

while true; do
  while read -r _event; do
    sleep 0.5
    update_last_non10_workspace
    if is_external_active; then
      next="connected"
    else
      next="disconnected"
    fi

    if [ "$state" = "disconnected" ] && [ "$next" = "connected" ]; then
      move_all_internal_workspaces_to_external
    elif [ "$next" = "connected" ] && needs_reconcile; then
      move_all_internal_workspaces_to_external
    fi

    state="$next"
  done < <(swaymsg -m -t subscribe '["output", "workspace"]' 2>/dev/null || true)

  sleep 1
done
