#!/usr/bin/env bash
set -euo pipefail

mic_mute_stamp="${XDG_RUNTIME_DIR:-/tmp}/mic-mute-toggle.stamp"
mic_mute_state="${XDG_RUNTIME_DIR:-/tmp}/mic-mute-toggle.state"
now="$(date +%s%3N)"
last="$(cat "$mic_mute_stamp" 2>/dev/null || true)"
if [[ "$last" =~ ^[0-9]+$ ]] && [ $((now - last)) -lt 750 ]; then
  exit 0
fi
printf '%s\n' "$now" > "$mic_mute_stamp" 2>/dev/null || true

source_id="$(wpctl status 2>/dev/null | awk '
  /Audio/ { in_audio = 1 }
  /Video/ { in_audio = 0 }
  in_audio && /Sources:/ { in_sources = 1; next }
  in_sources && /Filters:/ { in_sources = 0 }
  in_audio && in_sources && /Microphone/ && match($0, /[0-9]+\./) {
    id = substr($0, RSTART, RLENGTH - 1)
    if ($0 ~ /\*/) {
      print id
      exit
    }
    if (first == "") first = id
  }
  END { if (first != "") print first }
')"
if [ -z "$source_id" ]; then
  dunstify --app-name=audio --replace=2595 --urgency=critical --timeout=2000 \
    "Microphone" "No audio source found" || true
  exit 1
fi

# Coregate's wpctl @DEFAULT_AUDIO_SOURCE@ currently resolves to the speaker sink.
# Use the real PipeWire source id and do not touch ALSA Capture or speaker mute.
current="$(cat "$mic_mute_state" 2>/dev/null || true)"
if [ "$current" != 0 ] && [ "$current" != 1 ]; then
  current=0
  source_status="$(wpctl get-volume "$source_id" 2>/dev/null || true)"
  if printf '%s\n' "$source_status" | grep -q MUTED; then
    current=1
  fi
fi

if [ "$current" -eq 1 ]; then
  muted=0
  text="Unmuted"
else
  muted=1
  text="Muted"
fi
printf '%s\n' "$muted" > "$mic_mute_state" 2>/dev/null || true

wpctl set-mute "$source_id" "$muted" || true

sleep 0.35
wpctl set-mute "$source_id" "$muted" || true

# Keep the ThinkPad F4 mic LED in sync even if the kernel trigger lags.
led=/sys/class/leds/platform::micmute/brightness
if [ -w "$led" ]; then
  printf '%s\n' "$muted" > "$led" || true
fi

if command -v dunstify >/dev/null 2>&1; then
  dunstify \
    --app-name=audio \
    --replace=2595 \
    --urgency=low \
    --timeout=1000 \
    --icon=microphone-sensitivity-muted-symbolic \
    "Microphone" "$text" || true
fi
