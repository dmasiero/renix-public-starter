#!/usr/bin/env bash
set -euo pipefail

card="alsa_card.pci-0000_00_1f.3-platform-skl_hda_dsp_generic"
profile="HiFi (HDMI1, HDMI2, HDMI3, Mic1, Mic2, Speaker)"
sink="alsa_output.pci-0000_00_1f.3-platform-skl_hda_dsp_generic.HiFi__Speaker__sink"

is_dp1_connected() {
  if command -v xrandr >/dev/null 2>&1 && [ -n "${DISPLAY:-}" ]; then
    xrandr --query 2>/dev/null | awk '$1 == "DP-1" && $2 == "connected" { found = 1 } END { exit !found }' && return 0
  fi

  if command -v wlr-randr >/dev/null 2>&1 && [ -n "${WAYLAND_DISPLAY:-}" ]; then
    wlr-randr 2>/dev/null | awk '
      $1 == "DP-1" { in_dp1 = 1; next }
      /^[^[:space:]]/ { in_dp1 = 0 }
      in_dp1 && /Enabled:[[:space:]]+yes/ { found = 1 }
      END { exit !found }
    ' && return 0
  fi

  # Fallback for headless/user-systemd runs: DP-1 maps to HDMI1 on this audio card.
  pactl list cards 2>/dev/null | awk '
    /\[Out\] HDMI1:/ { in_hdmi1 = 1 }
    in_hdmi1 && /available/ { if ($0 ~ /available/) found = 1; in_hdmi1 = 0 }
    END { exit !found }
  '
}

if [ "${1:-}" = "--if-dp1" ] && ! is_dp1_connected; then
  exit 0
fi

pactl set-card-profile "$card" "$profile" >/dev/null 2>&1 || true
sleep 0.3

amixer -c 0 set Master unmute 100% >/dev/null 2>&1 || true
amixer -c 0 set Speaker unmute >/dev/null 2>&1 || true
amixer -c 0 set 'Bass Speaker' unmute >/dev/null 2>&1 || true

if pactl list short sinks 2>/dev/null | awk -v sink="$sink" '$2 == sink { found = 1 } END { exit !found }'; then
  pactl set-sink-mute "$sink" 0 >/dev/null 2>&1 || true
  pactl set-sink-volume "$sink" 100% >/dev/null 2>&1 || true
  pactl set-default-sink "$sink" >/dev/null 2>&1 || true

  pactl list short sink-inputs 2>/dev/null | awk '{ print $1 }' | while read -r input; do
    [ -n "$input" ] && pactl move-sink-input "$input" "$sink" >/dev/null 2>&1 || true
  done
fi
