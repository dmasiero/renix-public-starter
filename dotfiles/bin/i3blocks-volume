#!/usr/bin/env bash
set -euo pipefail

case "${BLOCK_BUTTON:-}" in
  1) pavucontrol >/dev/null 2>&1 & ;;
  3) wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle >/dev/null ;;
  4) wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%- -l 1.0 >/dev/null ;;
  5) wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+ -l 1.0 >/dev/null ;;
esac

status="$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null || true)"
if [ -z "$status" ]; then
  echo "n/a"
  exit 0
fi

if printf '%s\n' "$status" | grep -q 'MUTED'; then
  printf '\uf6a9<span size="3200"> </span>MUTE\n'
  exit 0
fi

volume="$(printf '%s\n' "$status" | awk '{ printf "%d", $2 * 100 }')"
printf '\uf028<span size="3200"> </span>%s%%\n' "$volume"
